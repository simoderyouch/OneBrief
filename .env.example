# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/freelancer_platform?schema=public"

# Optional pool tuning
# DATABASE_POOL_MAX=10
# DATABASE_CONNECT_TIMEOUT_MS=30000

# ─── NextAuth (freelancer dashboard) ────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# ─── Supabase Storage (file uploads) ────────────────────────────────────────
# Create a public bucket named "project-files" (50 MB limit recommended).
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ─── Email (Resend) ─────────────────────────────────────────────────────────
RESEND_API_KEY="re_your_api_key"
EMAIL_FROM="studio@yourdomain.com"

# ─── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Optional: production rate limiting (Upstash Redis) ─────────────────────
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# ─── Seed user (npm run db:setup) ───────────────────────────────────────────
# SEED_USER_EMAIL="admin@local.test"
# SEED_USER_PASSWORD="admin1234"

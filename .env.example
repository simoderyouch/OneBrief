# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/freelancer_platform?schema=public"

# ─── NextAuth (freelancer dashboard) ────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# ─── Storage ────────────────────────────────────────────────────────────────
# Local dev: leave STORAGE_PROVIDER unset (or "local")
# Production: set STORAGE_PROVIDER=spaces and fill in Spaces credentials
STORAGE_PROVIDER="local"
STORAGE_PATH="./storage/uploads"

# DigitalOcean Spaces (required when STORAGE_PROVIDER=spaces)
# SPACES_KEY="your-spaces-access-key"
# SPACES_SECRET="your-spaces-secret-key"
# SPACES_BUCKET="your-bucket-name"
# SPACES_REGION="nyc3"   # or ams3, sgp1, fra1, syd1

# ─── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Optional: production rate limiting (Upstash Redis) ─────────────────────
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# ─── Seed user (npm run db:setup) ───────────────────────────────────────────
# SEED_USER_EMAIL="admin@local.test"
# SEED_USER_PASSWORD="admin1234"
